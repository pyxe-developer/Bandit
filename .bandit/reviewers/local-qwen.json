{
  "contract_version": 1,
  "profile_id": "local-qwen-baseline",
  "version": 1,
  "runtime": "command",
  "command": {
    "executable": "qwen",
    "args": [
      "--bare",
      "--auth-type",
      "openai",
      "--openai-base-url",
      "http://localhost:11434/v1",
      "--openai-api-key",
      "ollama",
      "--model",
      "qwen3.6:35b-a3b-coding-mxfp8",
      "--approval-mode",
      "plan",
      "--output-format",
      "json",
      "--json-schema",
      "{\"type\":\"object\",\"required\":[\"verdict\",\"findings\",\"summary\"],\"properties\":{\"verdict\":{\"type\":\"string\",\"enum\":[\"pass\",\"non_blocking\",\"blocker\"]},\"findings\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"summary\":{\"type\":\"string\"}},\"additionalProperties\":false}",
      "{{prompt}}"
    ]
  },
  "model": "qwen3.6:35b-a3b-coding-mxfp8 via local Ollama",
  "prompt_contract": {
    "role": "read_only_adversarial_reviewer",
    "required_outputs": ["verdict", "findings", "summary"]
  },
  "timeout_ms": 180000,
  "permissions": {
    "filesystem": "read_only",
    "network": "disabled",
    "can_edit_files": false,
    "can_request_tools": false
  },
  "output_contract": {
    "format": "json",
    "required_fields": ["verdict", "findings", "summary"]
  },
  "unavailable_runtime_behavior": "fail_closed_or_bootstrap_gap"
}
