{
  "contract_version": 1,
  "profile_id": "local-qwen-baseline",
  "version": 1,
  "provider": "mastra-code",
  "provider_base_url": "http://127.0.0.1:8000/v1",
  "runtime": "command",
  "command": {
    "executable": "mastracode",
    "args": [
      "--model",
      "omlx-local/Qwen3.6-35B-A3B-MLX-8bit",
      "--output-format",
      "json",
      "--thinking-level",
      "off",
      "--timeout",
      "180",
      "--prompt",
      "{{prompt_stdin}}"
    ]
  },
  "model": "omlx-local/Qwen3.6-35B-A3B-MLX-8bit",
  "prompt_contract": {
    "role": "read_only_adversarial_reviewer",
    "required_outputs": ["verdict", "findings", "summary"]
  },
  "timeout_ms": 180000,
  "permissions": {
    "filesystem": "read_only",
    "network": "disabled",
    "can_edit_files": false,
    "can_request_tools": false
  },
  "output_contract": {
    "format": "json",
    "required_fields": ["verdict", "findings", "summary"]
  },
  "unavailable_runtime_behavior": "fail_closed_or_bootstrap_gap"
}
